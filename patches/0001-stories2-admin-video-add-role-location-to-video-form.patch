diff --git a/app/api/stories/route.ts b/app/api/stories/route.ts
new file mode 100644
index 0000000..be9b918
--- /dev/null
+++ b/app/api/stories/route.ts
@@ -0,0 +1,14 @@
+import { NextResponse } from 'next/server';
+import { getAllStories } from '@/lib/db';
+
+export async function GET() {
+  try {
+    const stories = await getAllStories();
+    // Return visible stories for the public site (do not require 'Approved' status)
+    const filtered = stories.filter(s => s.is_visible);
+    return NextResponse.json({ success: true, data: filtered });
+  } catch (err) {
+    console.error('GET /api/stories error', err);
+    return NextResponse.json({ success: false, error: 'Failed to fetch stories' }, { status: 500 });
+  }
+}
diff --git a/database/migrations/010_add_role_and_rename_summary.sql b/database/migrations/010_add_role_and_rename_summary.sql
new file mode 100644
index 0000000..ce632a2
--- /dev/null
+++ b/database/migrations/010_add_role_and_rename_summary.sql
@@ -0,0 +1,27 @@
+-- Migration: add role column and rename summary -> location
+-- This migration will:
+-- 1. Add a new `role` TEXT column (nullable)
+-- 2. Rename existing `summary` column to `location` so existing data is preserved
+
+ALTER TABLE stories
+  ADD COLUMN IF NOT EXISTS role TEXT;
+
+-- If summary exists and location does not, rename it; otherwise, create location and migrate
+DO $$
+BEGIN
+  IF EXISTS (
+    SELECT 1 FROM information_schema.columns
+    WHERE table_name='stories' AND column_name='summary'
+  ) AND NOT EXISTS (
+    SELECT 1 FROM information_schema.columns
+    WHERE table_name='stories' AND column_name='location'
+  ) THEN
+    ALTER TABLE stories RENAME COLUMN summary TO location;
+  ELSIF NOT EXISTS (
+    SELECT 1 FROM information_schema.columns
+    WHERE table_name='stories' AND column_name='location'
+  ) THEN
+    -- If somehow summary doesn't exist but location also doesn't, create location
+    ALTER TABLE stories ADD COLUMN location TEXT;
+  END IF;
+END$$;
