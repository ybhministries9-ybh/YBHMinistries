users ||--o{ gallery_items : "created_by / updated_by (implicit)"
users ||--o{ books : "created_by / updated_by (implicit)"
users ||--o{ worship : "created_by / updated_by (implicit)"
users ||--o{ sermons : "created_by / updated_by (implicit)"
users ||--o{ bible_studies : "created_by / updated_by (implicit)"
users ||--o{ reports : "created_by / updated_by (implicit)"
users ||--o{ home_hero_images : "created_by / updated_by (implicit)"
users ||--o{ home_video : "created_by / updated_by (implicit)"
users ||--o{ hero_images : "created_by / updated_by (implicit)"

